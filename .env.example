# PostgreSQL connection string from Supabase → Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ScraperAPI — bypasses Cloudflare/datacenter IP blocks on Railway
# Free tier: 1,000 req/month  →  https://www.scraperapi.com
# Without this key the scraper falls back to the UC browser (won't work on Railway)
SCRAPERAPI_KEY=your_scraperapi_key_here

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sender — must match a domain you've verified in Resend
# For local testing you can use:  onboarding@resend.dev  (no domain setup needed)
RESEND_FROM=PropSearch <you@yourdomain.com>

# Recipient for scrape-completion reports
REPORT_EMAIL=you@example.com
